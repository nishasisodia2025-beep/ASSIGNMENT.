import math

def is_strong_number(n):
    temp = n
    digit_sum = 0
    
    while temp > 0:
        digit = temp % 10
        digit_sum += math.factorial(digit)
        temp //= 10
        
    return digit_sum == n

# Test the program
num = int(input("Enter a number: "))
if is_strong_number(num):
    print(f"{num} is a Strong Number.")
else:
    print(f"{num} is NOT a Strong Number.")