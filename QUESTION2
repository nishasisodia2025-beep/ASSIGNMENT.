def is_symmetric(matrix):
    n = len(matrix)
    
    # Check if elements mirror perfectly across the main diagonal
    for i in range(n):
        for j in range(i):
            if matrix[i][j] != matrix[j][i]:
                return False
                
    return True

# --- Example Usage ---
symmetric_matrix = [,
 ,
    [3, 5, 6]
]

print("Is symmetric?", is_symmetric(symmetric_matrix))