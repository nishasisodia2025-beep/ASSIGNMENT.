#include<stdio.h>
int main()
{
    int low,high,i,j,isPrime;
    printf("Enter the lower and upper limits: ");
    scanf("%d %d",&low,&high);
    printf("Prime numbers between %d and %d are: ",low,high);
    for(i=low; i<=high; i++)
    {
        if(i <= 1)
        {
            continue; // Skip 0 and 1
        }
        isPrime = 1; // Assume i is prime until proven otherwise
        for(j=2; j*j <= i; j++)
        {
            if(i % j == 0)
            {
                isPrime = 0; // Found a divisor, not a prime number 
                break;
                }
            }
        }
        if (isPrime==1)
        {
            printf("%d",i);
            }
        }
        printf("\n");
        return 0;
    }
            
