def max_frequency_element(arr):
    if not arr:
        return None
        
    frequency_map = {}
    max_count = 0
    most_frequent_item = arr[0]
    
    for num in arr:
        frequency_map[num] = frequency_map.get(num, 0) + 1
        if frequency_map[num] > max_count:
            max_count = frequency_map[num]
            most_frequent_item = num
            
    return most_frequent_item