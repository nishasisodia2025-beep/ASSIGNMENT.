def binary_to_decimal(binary_str):
    decimal_val = 0
    power = 0
    
    # Iterate through the string from right to left
    for digit in reversed(binary_str):
        if digit == '1':
            decimal_val += 2 ** power
        power += 1
    return decimal_val

# Test the program
b_str = input("Enter a binary number: ")
print(f"Decimal value: {binary_to_decimal(b_str)}")