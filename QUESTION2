#include <stdio.h>

int main() {
    int n, i;
    int t1 = 0, t2 = 1, nthTerm = 0;

    printf("Enter the value of n: ");
    scanf("%d", &n);

    if (n == 1) {
        nthTerm = t1;
    } else if (n == 2) {
        nthTerm = t2;
    } else {
        for (i = 3; i <= n; i++) {
            nthTerm = t1 + t2;
            t1 = t2;
            t2 = nthTerm;
        }
    }

    printf("The %d-th Fibonacci term is: %d\n", n, nthTerm);

    return 0;
}