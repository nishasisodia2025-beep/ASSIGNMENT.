def recursive_fibonacci(n):
    # Base cases
    if n <= 0:
        return 0
    elif n == 1:
        return 1
    # Recursive case
    return recursive_fibonacci(n - 1) + recursive_fibonacci(n - 2)

# Test the program
num = int(input("Enter the position (n): "))
print(f"The Fibonacci number at position {num} is {recursive_fibonacci(num)}")