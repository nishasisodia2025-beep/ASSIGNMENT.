def reverse_sub段(arr, start, end):
    while start < end:
        arr[start], arr[end] = arr[end], arr[start]
        start += 1
        end -= 1

def rotate_left(arr, k):
    n = len(arr)
    if n == 0: return arr
    k = k % n  # Handle cases where k is greater than array length
    
    reverse_sub段(arr, 0, k - 1)  # Reverse first k elements
    reverse_sub段(arr, k, n - 1)  # Reverse remaining elements
    reverse_sub段(arr, 0, n - 1)  # Reverse the entire array
    return arr