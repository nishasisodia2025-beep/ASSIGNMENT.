def print_factors(n):
    print(f"The factors of {n} are:")
    # Loop from 1 to n to check for divisors
    for i in range(1, n + 1):
        if n % i == 0:
            print(i, end=" ")
    print()  # For new line

# Test the program
num = int(input("Enter a number: "))
print_factors(num)