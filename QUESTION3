def print_character_triangle(rows):
    for i in range(1, rows + 1):
        # ASCII value for 'A' is 65
        start_char = 65 
        for j in range(i):
            print(chr(start_char + j), end="")
        print() # Move to the next line

# Test the program
num_rows = int(input("Enter number of rows: "))
print_character_triangle(num_rows)