#include<stdio.h>
int main()
{
    int num, remainder, product = 1;
    printf("Enter a number: ");    
    scanf("%d", &num);
    if(num == 0)
    {
        product = 0;
    }
    if(num < 0)
    {
        num = -num; // Make the number positive for digit extraction
    }
    while(num != 0)
    {
        remainder = num % 10;
        product *= remainder;
        num /= 10;
    }
    printf("Product of digits is %d", product);
    return 0;   
}