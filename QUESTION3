#include <stdio.h>

int main() {
    int n1, n2, originalN1, originalN2, temp;

    printf("Enter two integers: ");
    scanf("%d %d", &n1, &n2);

    originalN1 = n1;
    originalN2 = n2;

    // Euclidean Algorithm to find GCD efficiently
    while (n2 != 0) {
        temp = n2;
        n2 = n1 % n2;
        n1 = temp;
    }

    printf("GCD of %d and %d = %d\n", originalN1, originalN2, n1);

    return 0;
}