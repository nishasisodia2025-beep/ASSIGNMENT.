def count_set_bits(n):
    count = 0
    while n > 0:
        # Brian Kernighan’s Algorithm to clear the lowest set bit
        n = n & (n - 1)
        count += 1
    return count

# Test the program
num = int(input("Enter an integer: "))
print(f"Number of set bits: {count_set_bits(num)}")