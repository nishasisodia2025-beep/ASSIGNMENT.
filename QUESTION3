def print_repeated_character(rows):
    for i in range(1, rows + 1):
        # ASCII value for 'A' is 65. Row 1 -> A, Row 2 -> B...
        current_char = chr(64 + i)
        print(current_char * i)

# Test the program
num_rows = int(input("Enter number of rows: "))
print_repeated_character(num_rows)