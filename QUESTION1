#include<stdio.h>
int main()
{
    int num,i,isPrime=1;
    printf("Enter a number: ");
    scanf("%d",&num);
    if(num <= 1)
    {
        isPrime = 0; // 0 and 1 are not prime numbers
    }
    else
    {
        for(i=2; i*i <= num; i++)
        {
            if(num % i == 0)
            {
                isPrime = 0; // Found a divisor, not a prime number
                break;
            }
        } 
    }   
    if(isPrime==1)
    {
        printf("%d is a prime number.",num);
    }
    else
    {
        printf("%d is not a prime number.",num);
    }
    return 0;
}