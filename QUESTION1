def recursive_factorial(n):
    # Base cases
    if n == 0 or n == 1:
        return 1
    # Recursive case
    return n * recursive_factorial(n - 1)

# Test the program
num = int(input("Enter a positive integer: "))
if num < 0:
    print("Factorial is not defined for negative numbers.")
else:
    print(f"Factorial of {num} is {recursive_factorial(num)}")