def decimal_to_binary(n):
    if n == 0:
        return "0"
    
    binary_str = ""
    while n > 0:
        remainder = n % 2
        binary_str = str(remainder) + binary_str
        n //= 2
    return binary_str

# Test the program
num = int(input("Enter a decimal number: "))
print(f"Binary representation: {decimal_to_binary(num)}")