def add_matrices(matrixA, matrixB):
    # Get dimensions
    rows = len(matrixA)
    cols = len(matrixA[0])
    
    # Initialize a result matrix filled with zeros
    result = [[0 for _ in range(cols)] for _ in range(rows)]
    
    # Perform element-wise addition
    for i in range(rows):
        for j in range(cols):
            result[i][j] = matrixA[i][j] + matrixB[i][j]
            
    return result

# --- Example Usage ---
# Define two 3x3 matrices
matrix_1 = [,
 ,
    [7, 8, 9]
]

matrix_2 = [,
 ,
    [3, 2, 1]
]

# Calculate sum
sum_matrix = add_matrices(matrix_1, matrix_2)

# Print the result
print("Resultant Matrix after Addition:")
for row in sum_matrix:
    print(row)