#include <stdio.h>

int main() {
    int n1, n2, originalN1, originalN2, temp, gcd, lcm;

    printf("Enter two integers: ");
    scanf("%d %d", &n1, &n2);

    originalN1 = n1;
    originalN2 = n2;

    // First, find the GCD using the Euclidean algorithm
    while (n2 != 0) {
        temp = n2;
        n2 = n1 % n2;
        n1 = temp;
    }
    
    gcd = n1;

    // Formula: LCM = (n1 * n2) / GCD
    // Division is done first to prevent potential integer overflow during multiplication
    lcm = (originalN1 / gcd) * originalN2;

    printf("LCM of %d and %d = %d\n", originalN1, originalN2, lcm);

    return 0;
}