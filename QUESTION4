#include <stdio.h>
#include <math.h>

int main() {
    int low, high, i, temp1, temp2, remainder, n;
    double result;

    printf("Enter lower bound and upper bound: ");
    scanf("%d %d", &low, &high);

    printf("Armstrong numbers between %d and %d are: \n", low, high);

    for (i = low; i <= high; ++i) {
        temp2 = i;
        temp1 = i;
        n = 0;
        result = 0.0;

        // Count digits for the current number
        while (temp1 != 0) {
            temp1 /= 10;
            ++n;
        }

        // Calculate power sum
        while (temp2 != 0) {
            remainder = temp2 % 10;
            result += pow(remainder, n);
            temp2 /= 10;
        }

        // Print if it matches
        if ((int)result == i) {
            printf("%d ", i);
        }
    }
    printf("\n");

    return 0;
}