def print_hollow_square(size):
    for i in range(1, size + 1):
        for j in range(1, size + 1):
            # Print '*' if it's the first/last row or first/last column
            if i == 1 or i == size or j == 1 or j == size:
                print("*", end="")
            else:
                print(" ", end="")
        print()

# Test the program
square_size = int(input("Enter size of the square: "))
print_hollow_square(square_size) 