def move_zeroes(arr):
    non_zero_pos = 0
    
    # Move all non-zero elements forward
    for i in range(len(arr)):
        if arr[i] != 0:
            arr[non_zero_pos] = arr[i]
            non_zero_pos += 1
            
    # Fill the rest of the array with zeroes
    while non_zero_pos < len(arr):
        arr[non_zero_pos] = 0
        non_zero_pos += 1
        
    return arr