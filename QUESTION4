def largest_prime_factor(n):
    largest = -1
    
    # Divide out all the 2s
    while n % 2 == 0:
        largest = 2
        n //= 2
        
    # Check odd numbers starting from 3 up to sqrt(n)
    for i in range(3, int(math.sqrt(n)) + 1, 2):
        while n % i == 0:
            largest = i
            n //= i
            
    # If n is still greater than 2, then n itself is prime
    if n > 2:
        largest = n
        
    return largest

# Test the program
import math
num = int(input("Enter a number: "))
result = largest_prime_factor(num)
print(f"The largest prime factor of {num} is {result}.")