def to_uppercase(string):
    result = ""
    for char in string:
        # Check if character is between 'a' and 'z'
        if 'a' <= char <= 'z':
            # Convert by shifting ASCII value by 32
            result += chr(ord(char) - 32)
        else:
            result += char
    return result

# --- Example Usage ---
text = "wipro"
print(f"Uppercase of '{text}':", to_uppercase(text))